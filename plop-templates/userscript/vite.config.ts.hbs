import { defineMonkeyConfig } from "@userscripts/shared/vite";

export default defineMonkeyConfig(import.meta.dirname, {
	name: "{{title}}",
	namespace: "{{namespace}}",
	description: "{{description}}",
	version: "{{version}}",
	match: [{{#each match}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
	grant: [{{#each grant}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
});
